# AI 代码知识图谱系统 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============================================================================
# LLM 配置（启用 AI 功能时必需）
# ============================================================================

# Anthropic Claude API（推荐）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 或使用 OpenAI GPT
# OPENAI_API_KEY=your_openai_api_key_here
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o

# 或使用本地 Ollama
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
# LLM_BASE_URL=http://localhost:11434/v1

# ============================================================================
# Neo4j 图数据库配置（可选，不配置则使用本地 JSON 存储）
# ============================================================================

# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your_neo4j_password

# ============================================================================
# 存储路径配置（可选，使用默认值即可）
# ============================================================================

# GRAPH_STORAGE_DIR=./data/graphs
# VECTOR_STORAGE_DIR=./data/chroma

# ============================================================================
# API 服务器配置（可选）
# ============================================================================

# API_HOST=0.0.0.0
# API_PORT=8000
# API_RELOAD=true

# ============================================================================
# 日志配置（可选）
# ============================================================================

# LOG_LEVEL=INFO
# LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
